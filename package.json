{
  "name": "elder-care-app",
  "version": "1.0.0",
  "description": "Elder Care Management System",
  "main": "server/index.js",
  "scripts": {
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "dev": "npm run build && npm start",
    "dev:watch": "concurrently \"cd client && npm start\" \"cd server && npm run dev\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "seed": "cd server && npm run seed",
    "create-test-user": "cd server && npm run create-test-user"
  },
  "keywords": [
    "elder-care",
    "healthcare",
    "caregiver"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.27.0"
  }
}
